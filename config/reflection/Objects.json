            "tags": [
              "IsPath",
              "VisibleIf:TextureLayout=Cross"
            ]
          },
          "TextureLayout": {
            "type": "enum",
            "enumType": "SkyboxTextureLayout",
            "default": "Individual",
            "order": 9
          }
        },
        "Appearance": {
          "Tint": {
            "type": "Color3",
            "default": [
              1,
              1,
              1
            ],
            "order": 10
          },
          "Filtering": {
            "type": "enum",
            "enumType": "TextureFiltering",
            "default": "Linear",
            "order": 11
          },
          "ResolutionCap": {
            "type": "int",
            "default": 1024,
            "order": 12
          },
          "Compression": {
            "type": "bool",
            "default": false,
            "order": 13
          }
        }
      }
    },
    "Image3D": {
      "categories": {
        "Transform": {
          "Position": {
            "type": "Vector3",
            "default": [
              0,
              0,
              0
            ],
            "order": 1
          }
        },
        "Data": {
          "ContentId": {
            "type": "string",
            "default": "",
            "description": "Image path (supports core:// and local:// prefixes).",
            "order": 2,
            "tags": [
              "IsPath"
            ]
          },
          "ResolutionCap": {
            "type": "int",
            "default": 1024,
            "description": "Maximum texture side length.",
            "order": 3
          }
        },
        "Appearance": {
          "FollowCamera": {
            "type": "bool",
            "default": true,
            "description": "When enabled, the image behaves like a billboard.",
            "order": 4
          },
          "ConstantSize": {
            "type": "bool",
            "default": true,
            "description": "When enabled, the image keeps an approximately constant size on screen.",
            "order": 5
          },
          "Tint": {
            "type": "Color3",
            "default": [
              1,
              1,
              1
            ],
            "description": "Tint color multiplied with the image.",
            "order": 6
          },
          "Transparency": {
            "type": "double",
            "default": 0,
            "description": "0 = opaque, 1 = invisible.",
            "order": 7
          },
          "AlwaysOnTop": {
            "type": "bool",
            "default": false,
            "description": "When enabled, the image renders without depth testing.",
            "order": 8
          },
          "NegateMask": {
            "type": "bool",
            "default": false,
            "description": "When enabled, the image negates (inverts) what is behind it using a mask.",
            "order": 9
          }
        },
        "Behavior": {
          "MaxDistance": {
            "type": "double",
            "default": 1000,
            "description": "Distance at which the image fades out.",
            "order": 6
          }
        },
        "Outline": {
          "OutlineEnabled": {
            "type": "bool",
            "default": false,
            "description": "Enable a screen-space outline based on image alpha edges.",
            "order": 10
          },
          "OutlineColor": {
            "type": "Color3",
            "default": [
              0,
              0,
              0
            ],
            "description": "Outline color.",
            "order": 11
          },
          "OutlineTransparency": {
            "type": "double",
            "default": 0,
            "description": "0 = opaque, 1 = invisible.",
            "order": 12
          },
          "OutlineThickness": {
            "type": "double",
            "default": 1,
            "description": "Outline thickness in texture pixels.",
            "order": 13
          }
        }
      }
    },
    "SelectionBox": {
      "categories": {
        "Data": {
          "Adornee": {
            "type": "InstanceRef",
            "order": 2
          }
        },
        "Appearance": {
          "Color": {
            "type": "Color3",
            "default": [
              0,
              0.25,
              1
            ],
            "order": 3
          },
          "Transparency": {
            "type": "double",
            "default": 0,
            "order": 4
          },
          "LineThickness": {
            "type": "double",
            "default": 0.05,
            "order": 5
          },
          "Metalness": {
            "type": "double",
            "default": 0,
            "order": 6
          },
          "Roughness": {
            "type": "double",
            "default": 0.5,
            "order": 7
          },
          "Emissive": {
            "type": "double",
            "default": 0,
            "order": 8
          },
          "IgnoreLighting": {
            "type": "bool",
            "default": true,
            "order": 9
          },
          "AlwaysOnTop": {
            "type": "bool",
            "default": false,
            "order": 10
          },
          "Visible": {
            "type": "bool",
            "default": true,
            "order": 11
          },
          "ScaleWithDistance": {
            "type": "bool",
            "default": false,
            "order": 12
          }
        }
      }
    },
    "Model": {
      "categories": {
        "Appearance": {
          "Renders": {
            "type": "bool",
            "default": true,
            "description": "When disabled, geometry within this model will not be rendered.",
            "order": 2
          }
        },
        "Data": {
          "PrimaryPart": {
            "type": "InstanceRef",
            "order": 3
          }
        }
      }
    },
    "Workspace": {
      "categories": {
        "Data": {
          "CurrentCamera": {
            "type": "InstanceRef",
            "readOnly": true,
            "order": 2
          }
        }
      }
    },
    "QualitySettings": {
      "categories": {
        "Quality": {
          "MSAA": {
            "type": "enum",
            "enumType": "MSAA",
            "default": "Off",
            "description": "Multisample anti-aliasing sample count.",
            "order": 2
          },
          "SurfaceMipmapping": {
            "type": "enum",
            "enumType": "SurfaceMipmapping",
            "default": "On",
            "description": "Mipmapped filtering for surface atlas textures.",
            "order": 3
          }
        }
      }
    },
    "Lighting": {
      "categories": {
        "Rendering": {
          "Ambient": {
            "type": "Color3",
            "default": [
              1,
              1,
              1
            ],
            "description": "Global ambient color.",
            "order": 2
          },
          "AmbientStrength": {
            "type": "double",
            "default": 0.1,
            "description": "Global ambient strength.",
            "order": 3
          },
          "Technology": {
            "type": "enum",
            "enumType": "LightingTechnology",
            "default": "Default",
            "description": "Controls the lighting style.",
            "order": 4
          },
          "Shading": {
            "type": "enum",
            "enumType": "LightingComputationMode",
            "default": "PerPixel",
            "description": "Selects per-fragment or legacy per-vertex lighting.",
            "order": 5
          },
          "FresnelAmount": {
            "type": "double",
            "default": 1,
            "description": "Scales Fresnel term contribution (0 disables angle-dependent Fresnel, 1 is default).",
            "order": 6
          }
        }
      }
    }
  }
}
