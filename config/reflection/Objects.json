            "order": 2
          },
          "Transparency": {
            "type": "double",
            "default": 0,
            "order": 3
          },
          "Roughness": {
            "type": "double",
            "default": 0.75,
            "order": 4
          },
          "Metalness": {
            "type": "double",
            "default": 0,
            "order": 5
          },
          "Emissive": {
